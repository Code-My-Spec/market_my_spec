<!DOCTYPE html>
<html lang="en" data-theme="marketmyspec-dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default="MarketMySpec" suffix=" · MarketMySpec">
      {assigns[:page_title]}
    </.live_title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500;700&family=Space+Mono:wght@700&display=swap"
      rel="stylesheet"
    />
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
    <script>
      (() => {
        const setTheme = (theme) => {
          if (theme === "system") {
            localStorage.removeItem("phx:theme");
            document.documentElement.setAttribute("data-theme", "marketmyspec-dark");
          } else {
            localStorage.setItem("phx:theme", theme);
            document.documentElement.setAttribute("data-theme", theme);
          }
        };
        const stored = localStorage.getItem("phx:theme");
        if (stored && stored !== "system") {
          document.documentElement.setAttribute("data-theme", stored);
        }
        window.addEventListener("storage", (e) => e.key === "phx:theme" && setTheme(e.newValue || "system"));
        window.addEventListener("phx:set-theme", (e) => setTheme(e.target.dataset.phxTheme));
      })();
    </script>
  </head>
  <body class="min-h-screen bg-base-100 text-base-content">
    <%!-- Public auth nav only. Authenticated pages get email/Settings/Log out
    from the app sidebar (Layouts.app), so this bar is hidden when signed in —
    it otherwise stacks above the min-h-screen drawer and forces a scrollbar. --%>
    <ul
      :if={is_nil(@current_scope)}
      class="menu menu-horizontal w-full relative z-10 flex items-center gap-4 px-4 sm:px-6 lg:px-8 justify-end border-b border-base-300 bg-base-200"
    >
      <li>
        <.link href={~p"/users/register"} class="font-mono text-xs hover:text-primary">Register</.link>
      </li>
      <li>
        <.link href={~p"/users/log-in"} class="btn btn-sm btn-primary">Log in</.link>
      </li>
    </ul>
    {@inner_content}
  </body>
</html>
