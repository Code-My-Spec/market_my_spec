#!/usr/bin/env bash
#
# Post-deploy hook. Two adjustments to the freshly-deployed container:
#
# 1. Re-attach the caddy_proxy network with the right alias.
#    Kamal's docker run lays down `--network kamal ... --network caddy_proxy
#    --network-alias <alias>`. Docker applies --network-alias to the FIRST
#    --network flag, so the alias lands on `kamal` instead of `caddy_proxy`.
#    We disconnect caddy_proxy and reconnect with the alias explicitly.
#
# 2. Connect db_net so the app can reach infra-postgres-1.
#
# The desired alias is read from the deploy config at runtime via the
# KAMAL_NETWORK_ALIAS env var (set in deploy.yml `env.clear`).

set -euo pipefail

SERVICE="${KAMAL_SERVICE:?service required}"
HOSTS="${KAMAL_HOSTS:?hosts required}"
DEST="${KAMAL_DESTINATION:-prod}"
case "$DEST" in
  ""|production|prod) ALIAS_ENV=prod ;;
  uat|staging)        ALIAS_ENV=uat  ;;
  *) ALIAS_ENV="$DEST" ;;
esac
ALIAS="${SERVICE}-${ALIAS_ENV}-web"

for host in ${HOSTS//,/ }; do
  echo "==> post-deploy on $host (alias=$ALIAS)"
  ssh "root@$host" "
    set -e
    cid=\$(docker ps --filter label=service=$SERVICE --filter status=running --format '{{.ID}}' | head -1)
    [[ -n \"\$cid\" ]] || { echo 'no running container found'; exit 1; }

    # Re-attach caddy_proxy with the right alias
    if docker inspect \$cid --format '{{range \$n, \$c := .NetworkSettings.Networks}}{{\$n}}={{\$c.Aliases}} {{end}}' | grep -qE \"caddy_proxy=\\[.*$ALIAS\"; then
      echo 'caddy_proxy already has the right alias'
    else
      docker network disconnect caddy_proxy \$cid 2>/dev/null || true
      docker network connect --alias $ALIAS caddy_proxy \$cid
      echo 'caddy_proxy re-attached with alias'
    fi

    # Connect db_net (idempotent)
    if docker inspect \$cid --format '{{json .NetworkSettings.Networks}}' | grep -q '\"db_net\"'; then
      echo 'db_net already connected'
    else
      docker network connect db_net \$cid
      echo 'db_net connected'
    fi
  "
done
