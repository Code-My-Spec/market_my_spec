# Kamal reads this as a Dotenv file — values like ${VAR} are interpolated
# from the environment of the kamal process. Populate the env first via
# scripts/deploy or scripts/deploy-uat, which source from AWS SSM Parameter
# Store (/market_my_spec/<env>/*) and from `gh auth token` for the registry.
#
# Direct `kamal deploy` invocation will fail unless these env vars are
# already exported. Always go through the scripts.
#
# This file is the SHORT list — Kamal carries only AWS bootstrap creds
# (so MarketMySpec.Secrets.load!/1 inside the container can fetch the
# rest from SSM at boot) plus the registry token for image pulls. App
# secrets are NEVER passed through here. See lib/market_my_spec/secrets.ex.

KAMAL_REGISTRY_PASSWORD=${KAMAL_REGISTRY_PASSWORD}
AWS_ACCESS_KEY_ID=${AWS_ACCESS_KEY_ID}
AWS_SECRET_ACCESS_KEY=${AWS_SECRET_ACCESS_KEY}
