# Kamal reads this as a Dotenv file — values like ${VAR} are interpolated
# from the environment of the kamal process. Populate the env first via
# `bin/deploy` (or `scripts/deploy*`), which sources from AWS SSM Parameter
# Store and from `gh auth token`.
#
# Direct `kamal deploy` invocation will fail unless these env vars are
# already exported. Always go through bin/deploy.

KAMAL_REGISTRY_PASSWORD=${KAMAL_REGISTRY_PASSWORD}
DATABASE_URL=${DATABASE_URL}
SECRET_KEY_BASE=${SECRET_KEY_BASE}
PHX_HOST=${PHX_HOST}
PHX_SERVER=${PHX_SERVER}
CLOAK_KEY=${CLOAK_KEY}
RESEND_API_KEY=${RESEND_API_KEY}
AWS_ACCESS_KEY_ID=${AWS_ACCESS_KEY_ID}
AWS_SECRET_ACCESS_KEY=${AWS_SECRET_ACCESS_KEY}
AWS_REGION=${AWS_REGION}
S3_BUCKET=${S3_BUCKET}
GOOGLE_CLIENT_ID=${GOOGLE_CLIENT_ID}
GOOGLE_CLIENT_SECRET=${GOOGLE_CLIENT_SECRET}
GITHUB_CLIENT_ID=${GITHUB_CLIENT_ID}
GITHUB_CLIENT_SECRET=${GITHUB_CLIENT_SECRET}
