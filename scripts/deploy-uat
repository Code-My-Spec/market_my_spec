#!/usr/bin/env bash
# Deploy MarketMySpec UAT to the Hetzner box.
# Same flow as scripts/deploy but uses /market_my_spec/uat/* SSM path and
# config/deploy.uat.yml. Image is shared — only env differs.

set -euo pipefail

REPO_ROOT=$(cd "$(dirname "$0")/.." && pwd)
DEVOPS_DIR="${DEVOPS_DIR:-$HOME/Documents/github/devops}"

cd "$REPO_ROOT"

if [[ -n "$(git status --porcelain)" ]]; then
  echo "ERROR: working tree has uncommitted changes." >&2
  git status --short >&2
  exit 1
fi

SHA=$(git rev-parse HEAD)
BRANCH=$(git rev-parse --abbrev-ref HEAD)

echo "==> pushing $BRANCH ($SHA) to origin..."
git push origin "$BRANCH"

echo "==> waiting for GitHub Actions build to finish..."
sleep 5
RUN_ID=$(gh run list --workflow=build.yml --branch="$BRANCH" --limit=1 --json databaseId --jq '.[0].databaseId')
[[ -n "$RUN_ID" ]] || { echo "no workflow run found" >&2; exit 1; }
gh run watch "$RUN_ID" --exit-status --interval 10

export KAMAL_REGISTRY_PASSWORD
KAMAL_REGISTRY_PASSWORD=$(gh auth token)

set -a
# shellcheck disable=SC1091
source <("$DEVOPS_DIR/scripts/render-env" market_my_spec uat)
set +a

# The shell that invoked this script likely has AWS_SESSION_TOKEN (and
# friends) set from an active SSO session. render-env's output sets the
# long-term IAM user credentials from SSM into AWS_ACCESS_KEY_ID /
# AWS_SECRET_ACCESS_KEY, but the SSO session token from the parent shell
# survives. Kamal's `env.secret` then ships all three into the container,
# AWS SDK treats the keys as STS creds (because session_token is present),
# and AWS rejects them with "UnrecognizedClientException: The security
# token included in the request is invalid." Clear them so the container
# sees only the long-term IAM pair.
unset AWS_SESSION_TOKEN AWS_SECURITY_TOKEN AWS_PROFILE

# Migrate against the NEW image before swapping traffic. See scripts/deploy
# for the full rationale.
echo "==> running migrations against $SHA before swapping traffic..."
kamal app exec -d uat --version="$SHA" "/app/bin/migrate"

kamal deploy -d uat --skip-push --version="$SHA" "$@"

echo "==> Done: https://uat.marketmyspec.com"
