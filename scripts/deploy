#!/usr/bin/env bash
# Deploy MarketMySpec PROD to the Hetzner box.
#
# Image build happens in GitHub Actions (.github/workflows/build.yml) on push
# to master. This script:
#   1. Verifies the working tree is clean and pushes commits.
#   2. Waits for the build workflow to finish.
#   3. Runs `kamal deploy --skip-push --version=<sha>` against the image
#      that the workflow just published.
#
# Secrets come from AWS SSM Parameter Store (/market_my_spec/prod/*).

set -euo pipefail

REPO_ROOT=$(cd "$(dirname "$0")/.." && pwd)
DEVOPS_DIR="${DEVOPS_DIR:-$HOME/Documents/github/devops}"

cd "$REPO_ROOT"

# 1. Working tree must be clean — Kamal versions by commit SHA
if [[ -n "$(git status --porcelain)" ]]; then
  echo "ERROR: working tree has uncommitted changes. Commit or stash before deploying." >&2
  git status --short >&2
  exit 1
fi

SHA=$(git rev-parse HEAD)
BRANCH=$(git rev-parse --abbrev-ref HEAD)

# 2. Push and trigger the build
echo "==> pushing $BRANCH ($SHA) to origin..."
git push origin "$BRANCH"

echo "==> waiting for GitHub Actions build to finish..."
sleep 5  # give GitHub a moment to register the trigger
RUN_ID=$(gh run list --workflow=build.yml --branch="$BRANCH" --limit=1 --json databaseId --jq '.[0].databaseId')
[[ -n "$RUN_ID" ]] || { echo "no workflow run found" >&2; exit 1; }
gh run watch "$RUN_ID" --exit-status --interval 10

# 3. Deploy via Kamal — pulls the just-built image from GHCR
export KAMAL_REGISTRY_PASSWORD
KAMAL_REGISTRY_PASSWORD=$(gh auth token)

set -a
# shellcheck disable=SC1091
source <("$DEVOPS_DIR/scripts/render-env" market_my_spec prod)
set +a

kamal deploy --skip-push --version="$SHA" "$@"

echo "==> Done: https://marketmyspec.com"
