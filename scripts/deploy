#!/usr/bin/env bash
# Deploy MarketMySpec PROD to the Hetzner box.
#
# Image build happens in GitHub Actions (.github/workflows/build.yml) on push
# to master. This script:
#   1. Verifies the working tree is clean and pushes commits.
#   2. Waits for the build workflow to finish.
#   3. Runs `bin/migrate` from the just-built image BEFORE traffic swaps,
#      so the new container never serves against a stale schema. (See the
#      "column subdomain does not exist" near-miss in commit history — a
#      deploy reported success while every request 500'd until migrations
#      caught up.)
#   4. Runs `kamal deploy --skip-push --version=<sha>` to swap traffic
#      to the new container.
#
# Secrets come from AWS SSM Parameter Store (/market_my_spec/prod/*).

set -euo pipefail

REPO_ROOT=$(cd "$(dirname "$0")/.." && pwd)
DEVOPS_DIR="${DEVOPS_DIR:-$HOME/Documents/github/devops}"

cd "$REPO_ROOT"

# 1. Working tree must be clean — Kamal versions by commit SHA
if [[ -n "$(git status --porcelain)" ]]; then
  echo "ERROR: working tree has uncommitted changes. Commit or stash before deploying." >&2
  git status --short >&2
  exit 1
fi

SHA=$(git rev-parse HEAD)
BRANCH=$(git rev-parse --abbrev-ref HEAD)

# 2. Push and trigger the build
echo "==> pushing $BRANCH ($SHA) to origin..."
git push origin "$BRANCH"

echo "==> waiting for GitHub Actions build to finish..."
sleep 5  # give GitHub a moment to register the trigger
RUN_ID=$(gh run list --workflow=build.yml --branch="$BRANCH" --limit=1 --json databaseId --jq '.[0].databaseId')
[[ -n "$RUN_ID" ]] || { echo "no workflow run found" >&2; exit 1; }
gh run watch "$RUN_ID" --exit-status --interval 10

# 3. Deploy via Kamal — pulls the just-built image from GHCR
export KAMAL_REGISTRY_PASSWORD
KAMAL_REGISTRY_PASSWORD=$(gh auth token)

# Render SSM bootstrap creds to a temp file with an explicit exit-code
# check. Process substitution (`source <(render-env …)`) swallows the
# inner command's failure — if SSO is stale, render-env prints nothing,
# source consumes nothing, and the deploy proceeds with empty AWS keys.
# That empty-creds state then propagates into kamal's per-host env-file
# and survives across every subsequent `kamal app exec` (which reuses
# the stale file without re-pushing). The temp-file approach makes the
# failure loud and immediate. See
# memory/feedback_deploy_render_env_silent_fail.md.
ENV_FILE=$(mktemp -t market_my_spec_prod_env.XXXXXX)
trap 'rm -f "$ENV_FILE"' EXIT

echo "==> rendering env from SSM (/market_my_spec/prod/*)..."
if ! "$DEVOPS_DIR/scripts/render-env" market_my_spec prod --out "$ENV_FILE"; then
  echo "ERROR: render-env failed. Run 'aws sso login' and retry." >&2
  exit 1
fi

set -a
# shellcheck disable=SC1091
source "$ENV_FILE"
set +a

# Clear any STS/SSO leftovers from the operator's shell. The container
# only needs the long-term IAM pair shipped from SSM; AWS_SESSION_TOKEN
# from the operator's session has no business in the container.
unset AWS_SESSION_TOKEN AWS_SECURITY_TOKEN AWS_PROFILE

# Hard-fail before kamal sees empty creds. Without this, kamal pushes
# an empty env-file to the host, the container crashes on boot, and
# every subsequent `kamal app exec` reuses the stale empty file.
for required in AWS_ACCESS_KEY_ID AWS_SECRET_ACCESS_KEY; do
  if [[ -z "${!required:-}" ]]; then
    echo "ERROR: $required is empty after render-env. Refusing to deploy" >&2
    echo "       — kamal would push an empty env-file and brick prod secrets." >&2
    exit 1
  fi
done

echo "==> bootstrap creds OK (AWS_ACCESS_KEY_ID ends ${AWS_ACCESS_KEY_ID: -4})"

# 3. Migrate the database against the NEW image, BEFORE swapping traffic.
# `kamal app exec --version=<sha>` boots a one-off container with the new
# image, runs the command, and removes the container. The currently-serving
# container is untouched — old traffic keeps flowing against the now-
# migrated schema until step 4 swaps in.
#
# Note: this assumes additive migrations (add column / add table). A
# destructive migration that drops a column the old code still reads would
# break the old container during this window — for that case, do the
# breaking change in two deploys (deploy code that stops reading the
# column first, then deploy code that drops it).
echo "==> running migrations against $SHA before swapping traffic..."
kamal app exec --version="$SHA" "/app/bin/migrate"

# 4. Swap traffic to the new container.
kamal deploy --skip-push --version="$SHA" "$@"

echo "==> Done: https://marketmyspec.com"
