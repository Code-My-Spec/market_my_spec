#!/usr/bin/env bash
# Roll the running market_my_spec container so it re-fetches SSM secret
# values. No image rebuild, no code change — the running container is
# replaced with one booted from the SAME image SHA, and Secrets.load!/1
# pulls fresh /<project>/<env>/* values from SSM at boot.
#
# Use after `rotate-secrets` to apply the new values to the live app.
#
# Usage:
#   ./scripts/roll-secrets prod
#   ./scripts/roll-secrets uat
#
# This script assumes git HEAD == the SHA currently deployed to the
# target env. If you push code without running ./scripts/deploy, the
# roll will swap traffic to your unbuilt commit (kamal will fail to
# pull the image and abort, but it's a wasted round-trip). To be safe,
# run this after a clean deploy or when working tree matches origin.

set -euo pipefail

ENV_NAME="${1:?usage: $0 <prod|uat>}"
[[ "$ENV_NAME" =~ ^(prod|uat)$ ]] || { echo "env must be prod or uat" >&2; exit 64; }

REPO_ROOT=$(cd "$(dirname "$0")/.." && pwd)
DEVOPS_DIR="${DEVOPS_DIR:-$HOME/Documents/github/devops}"
cd "$REPO_ROOT"

KAMAL_CONFIG="config/deploy.yml"
[[ "$ENV_NAME" == "uat" ]] && KAMAL_CONFIG="config/deploy.uat.yml"

if [[ -n "$(git status --porcelain)" ]]; then
  echo "WARNING: working tree has uncommitted changes." >&2
  echo "         The roll uses git HEAD ($(git rev-parse --short HEAD)) as the" >&2
  echo "         image SHA, which must match what's deployed. Continuing." >&2
fi

SHA=$(git rev-parse HEAD)

echo "==> rolling $ENV_NAME container against $SHA (no rebuild)..."

# Bootstrap creds — Kamal still needs AWS_* + APP_ENV on the host
# env-file even though we're not rotating bootstrap creds themselves.
# Re-render from SSM and re-push so the host file matches current SSM,
# even if nothing changed. Cheap insurance against drift.
export KAMAL_REGISTRY_PASSWORD
KAMAL_REGISTRY_PASSWORD=$(gh auth token)

ENV_FILE=$(mktemp -t market_my_spec_${ENV_NAME}_env.XXXXXX)
trap 'rm -f "$ENV_FILE"' EXIT

echo "==> rendering bootstrap env from SSM (/market_my_spec/${ENV_NAME}/*)..."
if ! "$DEVOPS_DIR/scripts/render-env" market_my_spec "$ENV_NAME" --out "$ENV_FILE"; then
  echo "ERROR: render-env failed. Run 'aws sso login' and retry." >&2
  exit 1
fi

set -a
# shellcheck disable=SC1091
source "$ENV_FILE"
set +a

unset AWS_SESSION_TOKEN AWS_SECURITY_TOKEN AWS_PROFILE

for required in AWS_ACCESS_KEY_ID AWS_SECRET_ACCESS_KEY; do
  if [[ -z "${!required:-}" ]]; then
    echo "ERROR: $required is empty after render-env. Refusing to roll." >&2
    exit 1
  fi
done

# Swap the container against the same image. kamal-proxy fronts traffic,
# so this is a rolling restart — no downtime when it works.
# --skip-push: don't try to push image (it's already on GHCR)
# --version=<sha>: pin to the running image, not a "latest" pointer
kamal deploy --skip-push --version="$SHA" -c "$KAMAL_CONFIG"

echo "==> Done. Container booted with fresh SSM values."
