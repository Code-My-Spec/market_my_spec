# Lives at /opt/market_my_spec/.env.uat on the UAT Hetzner host (chmod 600).
# Loaded by docker compose via --env-file. DATABASE_URL is passed straight
# through to the app and points at the host's infra-postgres-1 container
# (joined via the db_net external network).

PHX_HOST=uat.marketmyspec.com
SECRET_KEY_BASE=replace-with-mix-phx-gen-secret-output

# Postgres — full URL with the per-app user (market_my_spec_uat_app)
DATABASE_URL=ecto://market_my_spec_uat_app:replace-with-db-password@infra-postgres-1/market_my_spec_uat

# Cloak encryption key (32 bytes, base64)
CLOAK_KEY=replace-with-base64-encoded-32-byte-key

# AWS S3 — mms-uat-files IAM user credentials
AWS_REGION=us-east-1
S3_BUCKET=market-my-spec-uat
AWS_ACCESS_KEY_ID=replace-with-mms-uat-files-access-key
AWS_SECRET_ACCESS_KEY=replace-with-mms-uat-files-secret

# OAuth providers
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
GITHUB_CLIENT_ID=replace-with-github-client-id
GITHUB_CLIENT_SECRET=replace-with-github-client-secret

# Mailer
RESEND_API_KEY=replace-with-resend-api-key
