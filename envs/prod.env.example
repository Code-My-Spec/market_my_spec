PORT=8080
PHX_HOST=marketmyspec.com
SECRET_KEY_BASE=replace-with-mix-phx-gen-secret-output
DATABASE_URL=ecto://USER:PASS@HOST/market_my_spec_prod

# AWS S3 - bucket mms-prod-files IAM user credentials
AWS_REGION=us-east-1
S3_BUCKET=market-my-spec-prod
AWS_ACCESS_KEY_ID=replace-with-mms-prod-files-access-key
AWS_SECRET_ACCESS_KEY=replace-with-mms-prod-files-secret

# OAuth providers
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
GITHUB_CLIENT_ID=replace-with-github-client-id
GITHUB_CLIENT_SECRET=replace-with-github-client-secret

# Mailer
RESEND_API_KEY=replace-with-resend-api-key

# Cloak encryption key (base64, generate with: 32 random bytes |> Base.encode64)
CLOAK_KEY=replace-with-base64-encoded-32-byte-key
